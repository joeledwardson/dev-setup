FROM archlinux:base
ENV HOME=/root
WORKDIR $HOME

# claude code
RUN pacman -Syu --noconfirm curl
RUN curl -sSL https://claude.ai/install.sh | bash

# packages (see ./modules/nixos-base.nix for my default headless packages)
# NOTE: neovim is NOT installed via pacman — Arch ships bleeding-edge (0.12.x)
# which breaks nvim-treesitter (master branch). We pin to 0.11.x below to match
# the host NixOS environment.
RUN pacman -S --noconfirm \
openssh \
zsh \
fzf \
git \
eza \
man-db \
tmux \
direnv \
jq \
fastfetch \
fd \
github-cli \
ripgrep \
vim \
wget \
unzip \
net-tools \
file \
socat \
bat \
uv \
yazi \
git-delta \
ruff \
zellij \
sheldon \
go-task \
glab \
gcc make \
nodejs npm \
python python-pip \
postgresql-libs \
lua-language-server

# Pin neovim to match host (NixOS nixos-25.11 ships 0.11.x). Arch's bleeding-edge
# 0.12.x broke nvim-treesitter master branch — `node:range()` behaviour change
# causes "attempt to call method 'range' (a nil value)" on markdown/etc.
ARG NVIM_VERSION=v0.11.7
RUN curl -fsSL "https://github.com/neovim/neovim/releases/download/${NVIM_VERSION}/nvim-linux-x86_64.tar.gz" \
    | tar -xz -C /opt && \
    ln -s /opt/nvim-linux-x86_64/bin/nvim /usr/local/bin/nvim

# typescript-tools.nvim plugin needs `tsserver` (from typescript npm pkg) on PATH,
# otherwise it errors loudly every time you open a .ts/.js file.
RUN npm install -g typescript

# clean pacman cache
RUN pacman -Scc --noconfirm

ENV SHELL=/bin/zsh
ENV ZDOTDIR=$HOME/.config/zsh
ENV PATH="$HOME/.local/bin:$PATH"
ENV EDITOR=vim

RUN uv tool install dotbot
COPY . $HOME/dev-setup

# run dotbot
RUN dotbot -c $HOME/dev-setup/install.conf.yaml

# install lazy plugins (gcc/make needed for treesitter parsers + telescope-fzf-native)
RUN nvim --headless "+Lazy! sync" +qa

# install mason LSP servers/tools
RUN nvim --headless "+MasonToolsInstallSync" +qa

# change default shell
RUN chsh root -s /bin/zsh

# load zsh plugins
RUN sheldon lock

# generate ssh key for container
RUN ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N "" -q

# dont run initial prompt for login, see here: https://tessl.io/blog/configuring-claude-code/
COPY ./dev-image/claude.json $HOME/.claude.json

# claude yolo alias
COPY ./dev-image/zshrclocal $HOME/.config/zshrclocal
