FROM alpine:3.23.3
ENV HOME=/root
WORKDIR $HOME

# libstdc++ needed for claude code
RUN apk add bash curl libstdc++
# this takes forever to run so do it first
RUN curl -sSL https://claude.ai/install.sh | bash

# add alpine packages (see ./modules/nixos-base.nix for my default headless packages)
# this is a trimmed down set to keep the container small-ish
RUN apk add \
openssh-keygen \
openssh-client \
zsh \
fzf \
git \
eza \
man-pages \
tmux \
direnv \
jq \
fastfetch \
fd \
github-cli \
ripgrep \
vim \
neovim \
wget \
unzip \
net-tools \
file \
socat \
bat \
uv \
yazi \
skim \
delta \
go-task \
ncurses \
gcc musl-dev make \
nodejs npm \
python3 py3-pip \
lua-language-server \
ruff \
sheldon

# zellij - install from github release (alpine pkg is outdated)
RUN curl -L https://github.com/zellij-org/zellij/releases/latest/download/zellij-x86_64-unknown-linux-musl.tar.gz | tar xz -C /usr/local/bin

ENV SHELL=/bin/zsh
ENV ZDOTDIR=$HOME/.config/zsh
ENV PATH="$HOME/.local/bin:$PATH"
ENV EDITOR=vim

RUN uv tool install dotbot
COPY . $HOME/dev-setup

# DEBUG IT
RUN cat $HOME/dev-setup/install.conf.yaml

# run dotbot
RUN dotbot -c $HOME/dev-setup/install.conf.yaml

# install lazy plugins (gcc/make needed for treesitter parsers + telescope-fzf-native)
RUN nvim --headless "+Lazy! sync" +qa

# install mason LSP servers/tools
RUN nvim --headless "+MasonToolsInstallSync" +qa

# change default shell (see https://wiki.alpinelinux.org/wiki/Shell_management)
RUN apk add shadow
RUN chsh root -s "$(which zsh)"

# load zsh plugins
RUN sheldon lock

# dont run initial prompt for login, see here: https://tessl.io/blog/configuring-claude-code/
COPY ./dev-image/claude.json $HOME/.claude.json

# claude yolo alias
COPY ./dev-image/zshrclocal $HOME/.config/zshrclocal


