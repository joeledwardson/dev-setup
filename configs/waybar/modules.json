{
  "custom/phoenix": {
    "format": "рЯР¶вАНрЯФ•",
    "tooltip": true,
    "tooltip-format": "btw"
  },

  "custom/focus": {
    "exec": "~/.config/hypr/scripts/waybar-focus.sh",
    "return-type": "json",
    "exec-on-event": false,
    "restart-interval": 1,
    "format": "Monitor Status"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "warp-on-scroll": false,
    "format": "{name} {icon}",
    "show-special": true,
    "format-icons": {
      "urgent": "пБ™",
      "active": "пЖТ",
      "default": "пДС",
      "empty": "пТ™",
      "special": "вШѓ"
    }
  },
  "hyprland/window": {
    "separate-outputs": true
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пБЃ",
      "deactivated": "пБ∞"
    }
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon} {volume}% пКФ {format_source}",
    "format-bluetooth-muted": "ођ§ {icon}пКФ {format_source}",
    "format-muted": "ођ§ {format_source}",
    "format-source": "пД∞ {volume}%",
    "format-source-muted": "пД±",
    "format-icons": {
      "headphone": "пА•",
      "hands-free": "оєЩ",
      "headset": "оєЩ",
      "phone": "пВХ",
      "portable": "пВХ",
      "car": "пЖє",
      "default": ["пА¶", "пАІ", "пА®"]
    },
    "on-click": "pavucontrol"
  },
  "cpu": {
    "format": "пЛЫ  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "пГЙ  {}%",
    "tooltip": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "у∞ҐЭ  {capacity}%",
    "format-plugged": "пЗ¶  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
  },
  "clock": {
    "format": "{:%H:%M | %e %B} ",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "пВҐ<span foreground='red'><sup>пСД</sup></span>",
      "none": "пВҐ",
      "dnd-notification": "пЗЈ<span foreground='red'><sup>пСД</sup></span>",
      "dnd-none": "пЗЈ",
      "inhibited-notification": "пВҐ<span foreground='red'><sup>пСД</sup></span>",
      "inhibited-none": "пВҐ",
      "dnd-inhibited-notification": "пЗЈ<span foreground='red'><sup>пСД</sup></span>",
      "dnd-inhibited-none": "пЗЈ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "sleep 1 && swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "sleep 0.1 && swaync-client -d -sw",
    "escape": true
  }
}
