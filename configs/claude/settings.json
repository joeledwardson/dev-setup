{
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read",
      "Glob",
      "Grep",
      "Find",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(grep:*)",
      "Bash(cp:*)",
      "Bash(cd:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(which:*)",
      "Bash(gh issue view:*)",
      "Bash(gh search:*)",
      "Bash(gh repo view:*)",
      "Bash(echo:*)",
      "Bash(curl:*)",
      "Bash(zellij action list-panes:*)",
      "Bash(zellij action dump-screen:*)",
      "Bash(nix search:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --name \"zellij-attention::waiting::$ZELLIJ_PANE_ID\""
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-if-unfocused.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --name \"zellij-attention::completed::$ZELLIJ_PANE_ID\""
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-if-unfocused.sh"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "viMode": true
}
