{
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read",
      "Glob",
      "Grep",
      "Find",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(grep *)",
      "Bash(cd *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(which *)",
      "Bash(gh issue view *)",
      "Bash(gh search *)",
      "Bash(gh repo view *)",
      "Bash(echo *)",
      "Bash(curl *)",
      "Bash(zellij action list-panes *)",
      "Bash(zellij action dump-screen *)",
      "Bash(cat *)",
      "Bash(wc *)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-if-unfocused.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-if-unfocused.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "viMode": true
}
