{
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(grep *)",
      "Bash(cd *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(git log *)",
      "Bash(git show *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/joelyboy/dev-setup/configs/claude/notify-if-unfocused.sh 'Claude Code needs your attention'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/joelyboy/dev-setup/configs/claude/notify-if-unfocused.sh 'Task complete'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "voiceEnabled": true
}
